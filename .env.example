NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/banhang?schema=public
# Use JWT_SECRET for HS256 in non-production. Production should provide both JWT_PRIVATE_KEY and JWT_PUBLIC_KEY for RS256.
JWT_SECRET=dev-jwt-secret-change-me-1234567890
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ACCESS_TTL_SEC=3600
JWT_REFRESH_TTL_SEC=604800
TOKEN_HASH_SECRET=dev-token-hash-secret-change-me-1234567890
PAYMENT_WEBHOOK_SECRET=dev-payment-webhook-secret-change-me-1234567890
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAYMENT_URL=
VNPAY_RETURN_URL=
RESERVATION_TTL_MINUTES=15
RESET_PASSWORD_TTL_MINUTES=30
EMAIL_VERIFICATION_TTL_HOURS=24
APP_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
