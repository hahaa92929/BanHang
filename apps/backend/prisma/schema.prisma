generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  super_admin
  admin
  manager
  staff
  customer
  guest
}

enum AuthProvider {
  google
  facebook
  apple
  zalo
}

enum ProductStatus {
  draft
  active
  archived
}

enum OrderStatus {
  created
  confirmed
  shipping
  completed
  canceled
  returned
}

enum OrderNoteVisibility {
  internal
  customer
}

enum PaymentMethod {
  cod
  vnpay
  momo
  zalopay
  stripe
  paypal
  bank_transfer
}

enum PaymentStatus {
  pending
  authorized
  paid
  failed
  refunded
  partially_refunded
  canceled
}

enum ShippingMethod {
  standard
  express
  same_day
  pickup
}

enum ShippingCarrier {
  internal
  ghn
  ghtk
  jt
  viettel_post
  grab_express
}

enum ShippingStatus {
  pending
  packed
  in_transit
  delivered
  returned
  canceled
}

enum ReservationStatus {
  active
  consumed
  canceled
  expired
}

enum CouponType {
  fixed
  percent
  free_shipping
}

enum NotificationType {
  order
  system
  promotion
  security
}

enum NotificationChannel {
  in_app
  email
  sms
  push
}

enum ReviewStatus {
  pending
  published
  rejected
}

enum ProductQuestionStatus {
  pending
  published
  rejected
}

enum ReferralStatus {
  signed_up
  qualified
  rewarded
}

enum InventoryMovementType {
  reserve
  release
  adjustment
  import
  export
  transfer
}

enum StoreAppointmentStatus {
  requested
  confirmed
  completed
  canceled
}

enum PromotionKind {
  banner
  flash_sale
  popup
  newsletter
}

enum PromotionPlacement {
  home_hero
  home_flash_sale
  home_popup
  category_top
  checkout_sidebar
}

enum NewsletterSubscriptionStatus {
  pending
  active
  unsubscribed
}

model User {
  id                      String                   @id @default(cuid())
  email                   String                   @unique
  passwordHash            String
  fullName                String
  phone                   String?
  role                    UserRole                 @default(customer)
  referralCode            String?                  @unique
  referredById            String?
  emailVerifiedAt         DateTime?
  twoFactorSecret         String?
  twoFactorEnabledAt      DateTime?
  failedLoginAttempts     Int                      @default(0)
  lockedUntil             DateTime?
  lastLoginAt             DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  cartItems               CartItem[]
  cartCoupon              CartCoupon?
  compareItems            CompareItem[]
  orders                  Order[]
  reservations            InventoryReservation[]
  refreshSessions         RefreshSession[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  addresses               Address[]
  wishlistItems           WishlistItem[]
  wishlistShare          WishlistShare?
  priceAlerts            PriceAlert[]
  notifications           Notification[]
  notificationPreference  NotificationPreference?
  pushSubscriptions       PushSubscription[]
  cartReminderEvents      CartReminderEvent[]
  reviews                 Review[]
  reviewHelpfulVotes      ReviewHelpfulVote[]
  productQuestions        ProductQuestion[]        @relation("ProductQuestionAuthor")
  productQuestionUpvotes  ProductQuestionUpvote[]
  answeredQuestions       ProductQuestion[]        @relation("ProductQuestionAnswerer")
  socialAccounts          SocialAccount[]
  apiKeys                 ApiKey[]
  savedPaymentMethods     SavedPaymentMethod[]
  loyaltyRedemptions      LoyaltyRedemption[]
  customerTags            CustomerTag[]
  customerNotes           CustomerNote[]             @relation("CustomerNoteSubject")
  authoredCustomerNotes   CustomerNote[]             @relation("CustomerNoteAuthor")
  authoredOrderNotes      OrderNote[]                @relation("OrderNoteAuthor")
  referredBy              User?                    @relation("UserReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals               User[]                   @relation("UserReferrals")
  referralEvents          ReferralEvent[]          @relation("ReferralReferrer")
  referredEvent           ReferralEvent?           @relation("ReferralReferred")
  inventoryMovements      InventoryMovement[]      @relation("InventoryMovementActor")
  statusHistories         OrderStatusEvent[]       @relation("OrderStatusEventActor")

  @@index([referredById])
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  parentId    String?
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryTree")
  products    Product[]

  @@unique([name, parentId])
  @@index([parentId])
  @@index([isActive, sortOrder])
}

model Brand {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  logoUrl     String?
  website     String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@index([isActive])
}

model Product {
  id               String                     @id @default(cuid())
  sku              String                     @unique
  slug             String                     @unique
  name             String
  categoryId       String?
  brandId          String?
  description      String
  price            Int
  stock            Int
  rating           Float                      @default(0)
  tags             String[]
  status           ProductStatus              @default(active)
  isFeatured       Boolean                    @default(false)
  metaTitle        String?
  metaDescription  String?
  totalReviews     Int                        @default(0)
  totalSold        Int                        @default(0)
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  category         Category?                  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  brand            Brand?                     @relation(fields: [brandId], references: [id], onDelete: SetNull)
  cartItems        CartItem[]
  orderItems       OrderItem[]
  reservationItems InventoryReservationItem[]
  media            ProductMedia[]
  variants         ProductVariant[]
  inventoryLevels  InventoryLevel[]
  priceHistory     ProductPriceHistory[]
  compareItems     CompareItem[]
  wishlistItems    WishlistItem[]
  priceAlerts      PriceAlert[]
  reviews          Review[]
  questions        ProductQuestion[]
  inventoryMoves   InventoryMovement[]

  @@index([categoryId, status])
  @@index([brandId, status])
  @@index([price])
  @@index([createdAt])
  @@index([status, isFeatured])
}

model ProductVariant {
  id              String            @id @default(cuid())
  productId       String
  sku             String            @unique
  name            String
  attributes      Json?
  price           Int
  stock           Int               @default(0)
  isDefault       Boolean           @default(false)
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  product         Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems       CartItem[]
  orderItems      OrderItem[]
  reservationItems InventoryReservationItem[]
  inventoryLevels InventoryLevel[]
  inventoryMoves  InventoryMovement[]

  @@index([productId, isDefault])
  @@index([productId, isActive])
}

model InventoryLevel {
  id          String         @id @default(cuid())
  productId   String
  variantId   String
  warehouseId String
  available   Int
  reserved    Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  product     Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  warehouse   Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([variantId, warehouseId])
  @@index([productId, warehouseId])
  @@index([warehouseId, available])
}

model ProductMedia {
  id        String   @id @default(cuid())
  productId String
  url       String
  type      String
  altText   String?
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
}

model ProductPriceHistory {
  id            String   @id @default(cuid())
  productId      String
  price          Int
  previousPrice  Int?
  source         String?
  changedAt      DateTime @default(now())
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, changedAt])
}

model Address {
  id          String   @id @default(cuid())
  userId      String
  label       String?
  fullName    String
  phone       String
  province    String?
  district    String
  ward        String?
  addressLine String
  country     String   @default("Viet Nam")
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isDefault])
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  variantId String
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@unique([userId, productId, variantId])
  @@index([userId])
  @@index([variantId])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

model WishlistShare {
  id           String   @id @default(cuid())
  userId       String   @unique
  token        String   @unique
  title        String?
  isActive     Boolean  @default(true)
  expiresAt    DateTime?
  lastViewedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token, isActive])
  @@index([expiresAt])
}

model CompareItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId, createdAt])
}

model PriceAlert {
  id                String   @id @default(cuid())
  userId            String
  productId         String
  targetPrice       Int?
  isActive          Boolean  @default(true)
  lastNotifiedPrice Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId, isActive, createdAt])
  @@index([productId, isActive, targetPrice])
}

model Review {
  id                 String       @id @default(cuid())
  userId             String
  productId          String
  rating             Int
  title              String?
  content            String
  mediaUrls          String[]
  isVerifiedPurchase Boolean      @default(false)
  status             ReviewStatus @default(published)
  helpfulCount       Int          @default(0)
  adminReply         String?
  adminReplyAt       DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  product            Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  helpfulVotes       ReviewHelpfulVote[]

  @@unique([userId, productId])
  @@index([productId, status, createdAt])
  @@index([userId, createdAt])
}

model ReviewHelpfulVote {
  id        String   @id @default(cuid())
  userId    String
  reviewId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@unique([userId, reviewId])
  @@index([reviewId, createdAt])
  @@index([userId, createdAt])
}

model ProductQuestion {
  id          String                @id @default(cuid())
  userId      String
  productId   String
  question    String
  answer      String?
  status      ProductQuestionStatus @default(published)
  upvoteCount Int                   @default(0)
  answeredAt  DateTime?
  answeredById String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  user        User                  @relation("ProductQuestionAuthor", fields: [userId], references: [id], onDelete: Cascade)
  product     Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  answeredBy  User?                 @relation("ProductQuestionAnswerer", fields: [answeredById], references: [id], onDelete: SetNull)
  upvotes     ProductQuestionUpvote[]

  @@index([productId, status, createdAt])
  @@index([productId, upvoteCount, createdAt])
  @@index([userId, createdAt])
  @@index([answeredById])
}

model ProductQuestionUpvote {
  id         String          @id @default(cuid())
  userId     String
  questionId String
  createdAt  DateTime        @default(now())
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  question   ProductQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([questionId, createdAt])
  @@index([userId, createdAt])
}

model Coupon {
  id             String       @id @default(cuid())
  code           String       @unique
  type           CouponType
  value          Int
  minOrderAmount Int          @default(0)
  maxDiscount    Int?
  usageLimit     Int?
  usedCount      Int          @default(0)
  startsAt       DateTime
  expiresAt      DateTime
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  cartCoupons    CartCoupon[]
  orders         Order[]
  loyaltyRedemption LoyaltyRedemption?

  @@index([isActive, expiresAt])
}

model CartCoupon {
  userId    String   @id
  couponId  String
  appliedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@index([couponId])
}

model Order {
  id             String                @id @default(cuid())
  orderNumber    String                @unique
  userId         String
  reservationId  String?               @unique
  couponId       String?
  status         OrderStatus           @default(created)
  paymentMethod  PaymentMethod
  paymentStatus  PaymentStatus
  shippingMethod ShippingMethod
  shippingStatus ShippingStatus
  addressJson    Json
  notes          String
  subtotal       Int
  discountAmount Int                   @default(0)
  taxAmount      Int                   @default(0)
  shippingFee    Int
  total          Int
  currency       String                @default("VND")
  shippingCarrier ShippingCarrier?
  shippingServiceCode String?
  shippingLabelUrl String?
  trackingCode   String?
  confirmedAt    DateTime?
  shippedAt      DateTime?
  deliveredAt    DateTime?
  completedAt    DateTime?
  canceledAt     DateTime?
  returnedAt     DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  user           User                  @relation(fields: [userId], references: [id], onDelete: Restrict)
  reservation    InventoryReservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  coupon         Coupon?               @relation(fields: [couponId], references: [id], onDelete: SetNull)
  items          OrderItem[]
  history        OrderStatusEvent[]
  orderNotes     OrderNote[]
  trackingEvents ShippingTrackingEvent[]
  paymentEvents  PaymentWebhookEvent[]
  payments       Payment[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([trackingCode])
  @@index([shippingCarrier, shippingStatus])
}

model InventoryReservation {
  id         String                     @id @default(cuid())
  userId     String
  status     ReservationStatus          @default(active)
  expiresAt  DateTime
  consumedAt DateTime?
  canceledAt DateTime?
  expiredAt  DateTime?
  createdAt  DateTime                   @default(now())
  updatedAt  DateTime                   @updatedAt
  user       User                       @relation(fields: [userId], references: [id], onDelete: Restrict)
  items      InventoryReservationItem[]
  order      Order?

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
}

model InventoryReservationItem {
  id            String               @id @default(cuid())
  reservationId String
  productId     String
  variantId     String
  name          String
  unitPrice     Int
  quantity      Int
  reservation   InventoryReservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  product       Product              @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant       ProductVariant       @relation(fields: [variantId], references: [id], onDelete: Restrict)
  allocations   InventoryReservationAllocation[]

  @@index([reservationId])
  @@index([productId])
  @@index([variantId])
}

model InventoryReservationAllocation {
  id                String                   @id @default(cuid())
  reservationItemId String
  warehouseId       String
  quantity          Int
  reservationItem   InventoryReservationItem @relation(fields: [reservationItemId], references: [id], onDelete: Cascade)
  warehouse         Warehouse                @relation(fields: [warehouseId], references: [id], onDelete: Restrict)

  @@index([reservationItemId])
  @@index([warehouseId])
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  productId  String
  variantId  String?
  sku        String
  name       String
  unitPrice  Int
  quantity   Int
  totalPrice Int
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant    ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([variantId])
}

model OrderStatusEvent {
  id         String       @id @default(cuid())
  orderId    String
  fromStatus OrderStatus?
  toStatus   OrderStatus
  note       String?
  actorId    String
  createdAt  DateTime     @default(now())
  order      Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  actor      User         @relation("OrderStatusEventActor", fields: [actorId], references: [id], onDelete: Restrict)

  @@index([orderId, createdAt])
}

model OrderNote {
  id         String              @id @default(cuid())
  orderId    String
  authorId   String
  visibility OrderNoteVisibility @default(customer)
  content    String
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  order      Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  author     User                @relation("OrderNoteAuthor", fields: [authorId], references: [id], onDelete: Restrict)

  @@index([orderId, visibility, createdAt])
  @@index([authorId, createdAt])
}

model RefreshSession {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  userId     String
  userAgent  String?
  ipAddress  String?
  expiresAt  DateTime
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  userId     String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model EmailVerificationToken {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  userId     String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model SocialAccount {
  id             String       @id @default(cuid())
  userId         String
  provider       AuthProvider
  providerUserId String
  email          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId, provider])
}

model ApiKey {
  id         String   @id @default(cuid())
  userId     String
  name       String
  keyPrefix  String
  keyHash    String   @unique
  permissions String[]
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([keyPrefix])
}

model SavedPaymentMethod {
  id                  String        @id @default(cuid())
  userId              String
  gateway             String
  method              PaymentMethod
  label               String
  brand               String?
  last4               String?
  expiryMonth         Int?
  expiryYear          Int?
  tokenRef            String        @unique
  providerCustomerRef String?
  isDefault           Boolean       @default(false)
  metadata            Json?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isDefault, createdAt])
  @@index([userId, method, createdAt])
}

model CustomerTag {
  id        String   @id @default(cuid())
  userId    String
  key       String
  name      String
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId, createdAt])
}

model CustomerNote {
  id        String   @id @default(cuid())
  userId    String
  authorId  String
  title     String?
  content   String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation("CustomerNoteSubject", fields: [userId], references: [id], onDelete: Cascade)
  author    User     @relation("CustomerNoteAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([userId, isPinned, createdAt])
  @@index([authorId, createdAt])
}

model ReferralEvent {
  id              String         @id @default(cuid())
  referralCode    String
  referrerId      String
  referredUserId  String         @unique
  status          ReferralStatus @default(signed_up)
  rewardPoints    Int            @default(100)
  qualifiedOrderId String?
  qualifiedAt     DateTime?
  rewardGrantedAt DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  referrer        User           @relation("ReferralReferrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUser    User           @relation("ReferralReferred", fields: [referredUserId], references: [id], onDelete: Cascade)

  @@index([referrerId, status, createdAt])
  @@index([referralCode, createdAt])
  @@index([qualifiedOrderId])
}

model LoyaltyRedemption {
  id             String   @id @default(cuid())
  userId         String
  couponId       String   @unique
  pointsSpent    Int
  discountAmount Int
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupon         Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Payment {
  id             String                @id @default(cuid())
  orderId        String
  gateway        String
  method         PaymentMethod
  amount         Int
  currency       String                @default("VND")
  status         PaymentStatus         @default(pending)
  transactionId  String?
  metadata       Json?
  refundedAmount Int                   @default(0)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  order          Order                 @relation(fields: [orderId], references: [id], onDelete: Cascade)
  webhookEvents  PaymentWebhookEvent[]

  @@index([orderId, createdAt])
  @@index([status])
}

model PaymentWebhookEvent {
  eventId     String   @id
  gateway     String
  type        String
  orderId     String?
  paymentId   String?
  payload     Json
  processedAt DateTime @default(now())
  order       Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  payment     Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([paymentId])
  @@index([processedAt])
}

model Notification {
  id          String              @id @default(cuid())
  userId      String
  type        NotificationType
  channel     NotificationChannel @default(in_app)
  templateKey String?
  campaignKey String?
  title       String
  content     String
  data        Json?
  isRead      Boolean             @default(false)
  scheduledFor DateTime?
  deliveredAt DateTime?
  openedAt    DateTime?
  clickedAt   DateTime?
  readAt      DateTime?
  createdAt   DateTime            @default(now())
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([userId, channel, createdAt])
  @@index([templateKey])
  @@index([campaignKey])
  @@index([scheduledFor, deliveredAt])
}

model NotificationPreference {
  id               String   @id @default(cuid())
  userId           String   @unique
  orderInApp       Boolean  @default(true)
  orderEmail       Boolean  @default(true)
  promotionInApp   Boolean  @default(true)
  promotionEmail   Boolean  @default(false)
  securityInApp    Boolean  @default(true)
  securityEmail    Boolean  @default(true)
  systemInApp      Boolean  @default(true)
  systemEmail      Boolean  @default(false)
  pushEnabled      Boolean  @default(false)
  smsEnabled       Boolean  @default(false)
  marketingOptIn   Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model CartReminderEvent {
  id                   String   @id @default(cuid())
  userId               String
  notificationId       String?
  channel              NotificationChannel
  latestCartUpdatedAt  DateTime
  cartItemCount        Int
  subtotal             Int
  createdAt            DateTime @default(now())
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, latestCartUpdatedAt])
  @@index([notificationId])
}

model NotificationTemplate {
  id              String              @id @default(cuid())
  key             String
  channel         NotificationChannel
  subjectTemplate String?
  titleTemplate   String
  contentTemplate String
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@unique([key, channel])
  @@index([channel, isActive])
}

model SearchQueryEvent {
  id              String   @id @default(cuid())
  userId          String?
  query           String
  normalizedQuery String
  expandedTerms   String[]
  resultCount     Int
  source          String   @default("web")
  createdAt       DateTime @default(now())

  @@index([normalizedQuery, createdAt])
  @@index([resultCount, createdAt])
  @@index([createdAt])
}

model ContentPage {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  excerpt         String?
  content         String
  metaTitle       String?
  metaDescription String?
  isPublished     Boolean  @default(false)
  publishedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isPublished, publishedAt])
}

model BlogPost {
  id                String   @id @default(cuid())
  slug              String   @unique
  title             String
  excerpt           String?
  content           String
  coverImageUrl     String?
  tags              String[]
  readTimeMinutes   Int      @default(3)
  relatedProductIds String[]
  isPublished       Boolean  @default(false)
  publishedAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([isPublished, publishedAt])
}

model PromotionCampaign {
  id              String             @id @default(cuid())
  key             String             @unique
  name            String
  kind            PromotionKind
  placement       PromotionPlacement
  title           String
  subtitle        String?
  content         String?
  imageUrl        String?
  videoUrl        String?
  linkUrl         String?
  couponCode      String?
  discountPercent Int?
  startsAt        DateTime
  expiresAt       DateTime?
  priority        Int                @default(0)
  isActive        Boolean            @default(true)
  metadata        Json?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([placement, isActive, startsAt])
  @@index([kind, isActive, startsAt])
}

model NewsletterSubscriber {
  id                    String                       @id @default(cuid())
  email                 String                       @unique
  fullName              String?
  source                String?
  status                NewsletterSubscriptionStatus @default(pending)
  confirmationTokenHash String?
  confirmationSentAt    DateTime?
  confirmedAt           DateTime?
  unsubscribedAt        DateTime?
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt

  @@index([status, createdAt])
}

model StoreLocation {
  id            String             @id @default(cuid())
  slug          String             @unique
  name          String
  description   String?
  phone         String?
  email         String?
  province      String
  district      String
  ward          String?
  addressLine   String
  country       String             @default("Viet Nam")
  latitude      Float
  longitude     Float
  openingHours  Json?
  services      String[]
  mapsUrl       String?
  isActive      Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  appointments  StoreAppointment[]

  @@index([province, district, isActive])
  @@index([isActive, createdAt])
}

model StoreAppointment {
  id           String                 @id @default(cuid())
  storeId      String
  fullName     String
  phone        String
  email        String?
  service      String?
  scheduledFor DateTime
  notes        String?
  status       StoreAppointmentStatus @default(requested)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  store        StoreLocation          @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, scheduledFor])
  @@index([status, createdAt])
}

model ShippingTrackingEvent {
  id          String           @id @default(cuid())
  orderId      String
  status       ShippingStatus
  carrier      ShippingCarrier?
  code         String
  title        String
  description  String?
  location     String?
  occurredAt   DateTime
  source       String          @default("system")
  createdAt    DateTime        @default(now())
  order        Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, occurredAt])
  @@index([carrier, occurredAt])
}

model Warehouse {
  id        String              @id @default(cuid())
  code      String              @unique
  name      String
  city      String?
  isDefault Boolean             @default(false)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  inventoryLevels InventoryLevel[]
  reservationAllocations InventoryReservationAllocation[]
  movements InventoryMovement[]

  @@index([isDefault])
}

model InventoryMovement {
  id          String                @id @default(cuid())
  productId   String
  variantId   String?
  warehouseId String?
  actorId     String?
  type        InventoryMovementType
  quantity    Int
  note        String?
  createdAt   DateTime              @default(now())
  product     Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant     ProductVariant?       @relation(fields: [variantId], references: [id], onDelete: SetNull)
  warehouse   Warehouse?            @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  actor       User?                 @relation("InventoryMovementActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([productId, createdAt])
  @@index([variantId, createdAt])
  @@index([warehouseId, createdAt])
  @@index([actorId, createdAt])
}
